# Local-only template.
# Do not commit real credentials or personal recipient addresses.

NAVER_CLIENT_ID= 네이버 개발자센터에서 발급받은 Client ID
NAVER_CLIENT_SECRET= 네이버 개발자센터에서 발급받은 Client Secret

SMTP_HOST= smtp.도메인.com (ex: smtp.naver.com)
SMTP_USERNAME= 발신 이메일
SMTP_PASSWORD= 앱/애플리케이션 비밀번호
MAIL_SENDER= 발신이메일

REAL_RECIPIENTS= 실제 수신 이메일
TEST_RECIPIENTS= 테스트 숫신 이메일

# Recommendation quality/cap. The cap is not a fill target.
MIN_SCORE=15
MAX_ARTICLES=35

# Local semantic recommendation (industry/security/venture categories only).
SEMANTIC_RECOMMENDATION_ENABLED=true
SEMANTIC_EMBEDDING_DIR=model/embeddings
