# Do not commit real credentials or recipient addresses.
NAVER_CLIENT_ID=your_client_id
NAVER_CLIENT_SECRET=your_client_secret

SMTP_HOST=smtp.naver.com
SMTP_PORT=587
SMTP_USERNAME=sender@example.com
SMTP_PASSWORD=your_app_password
MAIL_SENDER=sender@example.com

TEST_MODE=true
TEST_RECIPIENTS=developer@example.com
REAL_RECIPIENTS=team@example.com
TIMEZONE=Asia/Seoul

# Recommendation quality/cap. The cap is not a fill target.
MIN_SCORE=15
MAX_ARTICLES=35
MMR_LAMBDA=0.70

# Local semantic recommendation (industry/security/venture categories only).
SEMANTIC_RECOMMENDATION_ENABLED=true
SEMANTIC_EMBEDDING_DIR=model/embeddings

# Set true only for local smoke tests without Naver credentials.
USE_SAMPLE_DATA=false
